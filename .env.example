# Same hostname as `npx convex dev` / Dashboard (do not mix two projects).
EXPO_PUBLIC_CONVEX_URL=https://flippant-mandrill-603.convex.cloud
# Must match Convex env CONVEX_SITE_URL (and usually SITE_URL), e.g. http://localhost:8081
EXPO_PUBLIC_CONVEX_SITE_URL=http://localhost:8081

# Optional: created by Convex CLI when you run `npx convex dev` — must match EXPO_PUBLIC_CONVEX_URL
# CONVEX_DEPLOYMENT=dev:your-deployment-name

# If multiple dev deployments exist under one project, set a deployment deploy key so
# `convex dev` pushes to the right one (see docs/CONVEX_MULTI_DEV.md). Never commit real keys.
# CONVEX_DEPLOY_KEY='dev:your-deployment-name|…'
